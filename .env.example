# ConciencIA Backend - Environment Variables
# Copiar a .env y llenar los valores

# Google Gemini (requerido para explicaciones IA, opcional para MVP)
GEMINI_API_KEY=

# Modelo de Gemini a usar
GEMINI_MODEL=gemini-2.0-flash

# OSRM (routing de OpenStreetMap) — servidor público por defecto
OSRM_BASE_URL=https://router.project-osrm.org

# CORS — orígenes permitidos (separados por coma en .env)
# Para desarrollo, permitir localhost
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Rate limiting
RATE_LIMIT_PER_MINUTE=30

# Logging
LOG_LEVEL=INFO
DEBUG=false
